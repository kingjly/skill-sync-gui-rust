{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Skill Sync GUI Rust",
  "version": "0.1.0",
  "identifier": "com.skillsync.gui.rust",
  "build": {
    "beforeDevCommand": "npm run dev:web",
    "beforeBuildCommand": "npm run tauri:prepare",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../web/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Skill Sync GUI Rust",
        "width": 1320,
        "height": 860,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
